/* Remove underline from all link states */
a:link,
a:visited,
a:hover,
a:active {
    text-decoration: none; /* Removes underline */
    color: inherit;        /* Optional: keeps text color same as parent */
}

/*Navigation bar things*/
.topnav {
  float: center;
  color: #f2f2f2;
  text-align: center;
  font-size: 16px;
}

/* Home page style and adjacent*/
.bio {
text-algin: center;
width: 100px;
}
